# CRK-model-HG 환경 설정 예시 — **냉장고(refrigerated) 기기 기본 템플릿**
#
# 사용법: 이 파일을 .env로 복사한 뒤 기기에 맞게 수정한다.
#   cp .env.example .env
# 냉동 기기는 냉동 실기 확정값이 정리된 freezer.env.example을 쓴다:
#   cp freezer.env.example .env
# .env는 serve.py(model-service-hg 기동)가 자동 로드한다. 이미 export된
# 환경변수가 있으면 그것이 우선한다 (os.environ.setdefault).
#
# 냉장 판정 경로는 프로파일(REFRIGERATOR: ±5g, 무게=정체성 판별자)이 자동
# 선택한다 — strict 중심 무게-우선 체인이 켜지고 FreezerVisionFirst·우도
# shadow 등 냉동 전용 로직은 precondition에서 스스로 꺼진다 (코드 수정 불요).

# ============================================================================
# 필수 — 기기마다 반드시 확인
# ============================================================================

# TensorRT 엔진 경로 (레포에 없음 — CRK-model에서 쓰던 .engine 복사)
MODEL__VISION__YOLO_MODEL_PATH=models/set9_doorfas_0323_imbal.engine

# 기기 캐비닛 타입: refrigerated | freezer
# 냉동 기기는 반드시 freezer로 — 미설정 시 냉장 프로파일(±5g, 무게=정체성)로
# 판정·정산되어 오과금/매출누락이 난다 (이슈 #6 실사고). 냉장 기기는
# refrigerated 명시 (기본값이지만 실수 방지를 위해 항상 적는다).
MODEL__MACHINE__CABINET_TYPE=refrigerated

# 카메라 레이아웃: dual(top+side, 냉장 기본) | dual_top_proxy(냉동 dual-top
# 전용 — 냉장 기기에서 설정 금지: side x-ROI가 꺼지고 수직 ROI 전제가 깨짐).
# 냉장 물리 구성이 top 1대 + 존별 side 5대여도 Edge가 존→{top, side} 2스트림
# 으로 매핑해 주므로 모델 계약은 그대로 dual이다 (camera-role-mapping).
MODEL__VISION__CAMERA_LAYOUT=dual

# ============================================================================
# 비전 투표 튜닝 (이슈 #6 — 세션 아카이브 YAML의 vote_summary를 보고 조정)
# ============================================================================
# 판정 흐름: YOLO 검출 → (진입 컷) → 투표 누적 → (ratio/count 게이트)
#            → (conf_floor) → vision_candidates → strict/vision 판정
# vote_summary 읽는 법:
#   entry_dropped_by_camera 큼  → 진입 컷이 너무 높음 (아래 THRESHOLD 낮추기)
#   rejected_by: "ratio"        → 투표 수 부족 (MIN_VOTE_RATIO/COUNT 낮추기)
#   rejected_by: "conf_floor"   → 결합 후 하한에 걸림 (CONF_FLOOR 낮추기)
#   filter_drops_by_stage 큼    → side_roi/top_roi/hand_path 필터가 지움 (ROI 경계 확인)
#   classes 자체가 비어 있음    → 모델이 정말 못 봄 (모델/카메라 문제)

# 카메라별 투표 진입 임계 — 이 conf 미만 검출은 투표에 안 들어감.
# 원본 코드 기본 0.70, 원본 냉장 운영 .env은 0.50 — 냉장 초기값은 원본
# 운영값에서 출발한다. 후보가 안 잡히면 0.35까지 낮춰 보고, 유령 후보가
# 늘면 다시 올린다 (냉동 실기에서는 top 0.4까지 내렸었음).
MODEL__VISION__TOP_CONFIDENCE_THRESHOLD=0.50
MODEL__VISION__SIDE_CONFIDENCE_THRESHOLD=0.50

# 후보 채택 임계: 투표율(votes/게이트 통과 프레임) 또는 절대 투표 수 중 하나만
# 넘으면 후보 유지. 원본 냉장 운영값 ratio 0.02 / count 1 (코드 기본 0.05 / 3).
# 노이즈 후보가 자주 살아남으면 count를 2~3으로 올려 본다 (냉동 실기는 2).
MODEL__VISION__MIN_VOTE_RATIO=0.02
MODEL__VISION__MIN_VOTE_COUNT=1

# 1위 후보 득표 대비 상대 하한 (이슈 #10, HG 고유 안전판). 절대 COUNT는
# 400프레임+ 영상에서 노이즈도 통과시킨다 — 8표(1위의 4%)짜리 후보가 판정에
# 들어가 무게만 맞으면 채택되는 사고(비비고 → 메로나 79g×3)의 원인.
# votes < 1위×SHARE 후보 제거. 0 = 비활성. vote_summary rejected_by: "share".
MODEL__VISION__MIN_VOTE_SHARE=0.1

# 결합 후 weighted_conf 하한 — 원본에는 없는 안전판 (원본 동형 = 0.0).
# 진입 컷을 0으로 낮춰 저신뢰 투표까지 보존할 때만 0.1~0.4로 올려 쓴다.
MODEL__VISION__CONF_FLOOR=0.0

# 카메라 conf 결합 가중 (원본 combine() 동형 산식 — P1-4):
#   양카메라 검출: weighted = top·W_TOP + side·W_SIDE
#                            + min(top,side)·COMMON_CLASS_BONUS
#   단일 카메라:   weighted = conf·W_TOP_ONLY (또는 W_SIDE_ONLY)
# 기본은 원본 운영값(0.60/0.40/0.2). 냉장은 존 전용 side가 근접 촬영이라
# side 신뢰도가 냉동(공용 광각)보다 높을 수 있다 — 실측 후 조정
# (냉동 실기 확정값은 0.70/0.30/0.80/0.40, freezer.env.example).
MODEL__VISION__CONF_WEIGHT_TOP=0.60
MODEL__VISION__CONF_WEIGHT_SIDE=0.40
MODEL__VISION__CONF_WEIGHT_TOP_ONLY=0.60
MODEL__VISION__CONF_WEIGHT_SIDE_ONLY=0.40
MODEL__VISION__CONF_COMMON_CLASS_BONUS=0.2

# Side 카메라 ROI 경계 (center_x >= 이 값이면 존 바깥으로 보고 제거) —
# 냉장 dual 레이아웃에서 실동작하는 필터다. 좌표계는 center-crop 480×480
# (2026-07-24 left-crop에서 전환) — 400은 원본 left-crop 좌표계 값을 그대로
# 이식한 것으로, 크롭 원점 이동(가로 0→80) 때문에 물리적으로는 옛 경계보다
# 오른쪽 80px 지점을 가리킨다. 옛 경계와 같은 위치를 원하면 320 —
# **냉장 실기 투입 시 카메라 장착 기준으로 재측정할 것** (필드테스트 플랜 참조).
MODEL__VISION__SIDE_ROI_MAX_CENTER_X=400

# Top 카메라 수직 ROI (원본 top_roi_enabled — 냉장 dual 레이아웃 전용):
# 트리거 delta가 0이 아닐 때 하단 절반(center_y >= Y_SPLIT)만 유지.
# 냉장은 top 공용 카메라 1대가 여러 존 진열을 넓게 보므로 이 ROI가 진열
# 오투표의 1차 방어선이다 (perf-gap §5 — 원본 기본 true, 냉장 투입 시
# 켜는 것을 권장). Y_SPLIT 240은 원본 운영값 — 실기 재측정 대상.
MODEL__VISION__TOP_ROI_ENABLED=1
MODEL__VISION__TOP_ROI_Y_SPLIT=240.0

# (냉동 dual-top 전용 수직 ROI FREEZER_ROI_*는 냉장 기기와 무관 —
#  freezer.env.example 참조. dual 레이아웃에서는 코드가 적용하지 않는다.)

# 손 검출 conf 하한 (원본 hand_confidence_threshold, P1-7 이식) — 이 값
# 미만의 hand 검출은 모션 게이트 래치(I16)·hand_path 궤적에 쓰지 않는다.
# 원본 운영값 0.30. 0 = 비활성.
MODEL__VISION__HAND_CONFIDENCE_THRESHOLD=0.30

# ============================================================================
# 로드셀 판정 (이슈 #10)
# ============================================================================
# 오염 delta 이중 타깃 재시도: 취출 시 손이 선반을 누르면(접촉 하중) delta와
# 세그먼트 합이 어긋난다(실측 8~18g, 깨끗한 트리거는 0). 이 갭이 아래 값을
# 넘고 delta 타깃 판정이 실패하면 세그먼트 합을 타깃으로 1회 재판정한다.
# YOLO 재실행 없음(순수 CPU, 수 ms). 아주 크게 주면 사실상 비활성.
MODEL__WEIGHT__SEGMENT_RETRY_GAP_GRAMS=5.0

# 로드셀 안정 판정 (이슈 #14, 0.8s 캐던스): plateau 성립에 STABLE_WINDOW개
# 연속 샘플의 std ≤ STABILITY_THRESHOLD 필요. post-roll 4s = 5샘플이라
# window 3은 마진이 얇다 — delta 0(insufficient_stable_regions)이 잦으면
# 카메라 post-roll 연장이 1순위. threshold 2.5는 5g 양자화 bin 경계 토글
# 1회 허용값 — 2.0이면 경계값이 영영 안정 판정을 못 받는다.
MODEL__WEIGHT__STABLE_WINDOW=3
MODEL__WEIGHT__STABILITY_THRESHOLD_GRAMS=2.5

# primary 로드셀 분석기: **bocpd 기본 (2026-07-23 정식 승격, 냉동 실측
# 63관측/2 mismatch → 이후 17건 mismatch 0).** 계약(reason/게이트/반품
# 안정화/멀티트레이 이벤트)은 plateau와 동일하고 "안정 구간" 정의만 다르다.
# 냉장 실기에서 delta 회귀가 보이면 plateau로 롤백 (killswitch).
MODEL__LOADCELL__ANALYZER=bocpd

# ============================================================================
# 판정 노브 — 냉동 존 전용 (냉장 판정 경로에서는 미사용)
# ============================================================================
# 아래 블록은 FreezerVisionFirst(무게=거부권, 선택=vision) 단계별 임계로,
# **cabinet_type=freezer이거나 MODEL__ZONES__FREEZER로 지정한 존에서만**
# 쓰인다. 냉장 존은 무게가 정체성 판별자(±5g)라 strict 체인이 담당 —
# 값을 남겨 둬도 무해하다 (혼합 기기 대비 기본값 유지).
MODEL__JUDGMENT__SINGLE_SHARE=0.5
MODEL__JUDGMENT__COMBO_SHARE=0.3
MODEL__JUDGMENT__NEAR_FACTOR=2.0
MODEL__JUDGMENT__REFIT_SHARE=0.1
# 무게 중재 재설계 (이슈 #16, docs/0722_issue16_arbitration_design.md):
# gate_n(n)=gate+slack×(n−1) / conf 자격·중재 격차. 냉동 존 전용.
MODEL__JUDGMENT__COUNT_UNIT_SLACK=5.0
MODEL__JUDGMENT__CONF_OVERRIDE=0.9
MODEL__JUDGMENT__CONF_MARGIN=0.15
# refit 복수 적합 중재의 절대 conf 하한 (승자는 자체로 선명해야 한다).
MODEL__JUDGMENT__REFIT_ARB_CONF_FLOOR=0.8
# 무게 미검증 count=1 partial 청구의 conf 하한 (원본 multi_kind_min_confidence
# 동형) — vision_first identity partial(냉동 존 전용)의 저증거 청구 차단.
MODEL__JUDGMENT__PARTIAL_MIN_CONFIDENCE=0.18

# 무게 우도 score shadow (docs/0722_weight_likelihood_design.md Phase 1) —
# **냉동 존 전용** (weight_is_discriminative=False에서만 applicable).
# 냉장 존에서는 아무것도 기록하지 않는다. 판정 미사용, 아카이브 diff만.
MODEL__JUDGMENT__LIKELIHOOD_SHADOW=1
MODEL__JUDGMENT__LIKELIHOOD_K=20.0
MODEL__JUDGMENT__LIKELIHOOD_SIGMA_DB=6.3

# 세션 트레이 메모리 (ledger/tray_memory.py) — 기록은 캐비닛 무관, 소비는
# 현재 우도 shadow의 log_p_tray 항뿐이라 냉장 존 판정에는 영향 0.
# 세션 OPEN마다 리셋 — 정적 planogram(금지)과 달리 운영 입력이 없다.
MODEL__JUDGMENT__TRAY_PRIOR=1
MODEL__JUDGMENT__TRAY_PRIOR_BOOST=0.7
MODEL__JUDGMENT__TRAY_PRIOR_PENALTY=2.5

# ============================================================================
# 조기 종료 · 모션 게이트 (프레임 처리량)
# ============================================================================
# EARLY_TERMINATION: removal & 비freezer 한정 — **냉장에서는 실제로 켜진다**
# (freezer는 I15로 항상 비활성이었으므로 냉동 실기에서 검증된 적 없음).
# 다품목 동시 취출에서 2번째 상품 증거 수집 전 중단 위험(perf-gap §8.5)이
# 있어 냉장 초기 배치는 0(전 프레임 추론)과 1을 A/B 비교 권장.
MODEL__VISION__EARLY_TERMINATION=1
# 모션 변위 증거 (issue #16 후속 — 원본 MOTION_MIN_DISPLACEMENT_PX 이식):
# 클래스 트랙의 누적 변위가 max(floor, bbox×0.10)을 못 넘으면 그 카메라의
# 표를 combine에서 몰수. "집어간 상품은 움직이고 진열 상품은 안 움직인다"의
# 직접 검사 — 구 static_track/baseline(은퇴)이 대리 신호로 쫓던 물리의
# 일반해다. vote_summary의 rejected_by: "no_motion" + motion_evidence 블록.
# FLOOR 비우면 프로파일 기본(냉장 10/냉동 12px — 원본 운영값 동형).
# 0=비활성 (롤백).
MODEL__VISION__MOTION_EVIDENCE=1
# MODEL__VISION__MOTION_EVIDENCE_FLOOR_PX=
# T2 held 트랙 강등 (0723 트랙릿 문서 §8): 프리롤 head 구간부터 지속
# 관측된(carried-in) 트랙의 표를 combine에서 몰수. 모드: off / shadow
# (vote_summary.held_shadow 관측만) / active. 승격 게이트: analyze-sessions
# 에서 정답 클래스 held 플래그 0건 확인 후 (10차 5건·11차 3건 → 보류 중).
MODEL__VISION__HELD_TRACK_DEMOTION=shadow
MODEL__VISION__HELD_TRACK_MIN_HEAD=5
# 트랙릿 잔여 갭 (0723 트랙릿 문서 §2, shadow-first — vote_summary.
# tube_shadow + analyze-sessions "튜브 shadow" 라벨 대조가 승격 게이트).
# 냉동 10차 실기 판정: tube 0:3:2 현행 우세 / recovery 산탄 증폭 —
# 승격 보류 (검토 권고 문서 참조). 냉장 실기에서 재평가.
MODEL__VISION__TUBE_IDENTITY=shadow
MODEL__VISION__VOTE_RECOVERY=shadow
MODEL__VISION__VOTE_RECOVERY_FLOOR=0.35
MODEL__VISION__TRACK_MIN_HITS=0
MODEL__VISION__TRACK_MAX_GAP=0
# MOTION_GATE_*: 비우면 프로파일 기본(냉장 0.02/8, 냉동 0.005/4) 유지.
# THRESHOLD를 올리면 스킵 증가(처리 절약), 내리면 거의 전 프레임 추론.
# MODEL__VISION__MOTION_GATE_THRESHOLD=
# MODEL__VISION__MOTION_GATE_KEEPALIVE=

# ============================================================================
# 교차존 비전 오염 페널티 (docs/cross_zone_penalty.md, CLOSE 2차 패스)
# ============================================================================
# 세션 유지 중 타 존 취출 장면이 판별용 AVI에 섞이는 오염을 CLOSE 2차 패스에서
# soft 페널티로 보정한다. Phase 3 승격 완료 (2026-07-21): 기본 ON — 캐비닛
# 무관 동작 (냉장은 무게 게이트가 좁아 발동 빈도가 낮다 — 안전 방향).
MODEL__CROSS_ZONE__PENALTY_ENABLED=1
# 오염 창 = [min앵커−REPLAY−ε, max앵커+TRIGGER+ε] — CRK-CAMERA 계약
# (replay_duration/trigger duration)과 단일 소스로 맞출 것.
MODEL__CROSS_ZONE__REPLAY_S=4.0
MODEL__CROSS_ZONE__TRIGGER_S=4.0
# IO-BOARD 감지 지연 마진 (ε): 폴링 0.8s(지배 항) + serial/SSE ~0.1s + 여유.
MODEL__CROSS_ZONE__EPSILON_S=1.0
# soft 페널티 계수 (α) — 오염 후보의 표·신뢰도에 곱한다 (하드 제외 아님)
MODEL__CROSS_ZONE__ALPHA=0.5
# SOURCE_CONF_MIN: 페널티 소스로 인정할 최소 판정 conf (오판 전파 차단, θ).
#   0.35 권장 — 0.5는 저conf 난장 장면에서 기제 전체를 꺼버린다 (9차 ses-8).
#   상호 강등의 안전은 mutual_exempt 가드가 따로 담당.
MODEL__CROSS_ZONE__SOURCE_CONF_MIN=0.35

# ============================================================================
# 세션 고스트 원장 (0723 이슈 #17 P1, ledger/ghost_ledger.py, CLOSE 2차 패스)
# ============================================================================
# 옷 프린트 유령 표(냉동 실측 c13·c24): 사람을 따라다니며 존마다 자격 표를
# 얻지만 세션 전체에서 무게 뒷받침(COMPLETE, refit/near_gate 제외) 과금이
# 0인 클래스를 강등. 캐비닛 무관 동작. MODE: off | shadow | active —
# shadow(기본)는 notes 기록만. active 승격은 라벨 대조에서 정답 클래스
# 오플래그율 확인 후 (11차: 에피소드 공유 결함 수정, shadow 유지 중).
MODEL__GHOST__MODE=shadow
MODEL__GHOST__MIN_ZONES=2
MODEL__GHOST__VOTE_FLOOR=3
MODEL__GHOST__ALPHA=0.5

# ============================================================================
# 존 프로파일 (선택)
# ============================================================================
# cabinet_type이 기본 프로파일을 정하고, 특정 존만 냉동으로 오버라이드할 때
# 사용 (냉장 기기의 냉동 코너 등)
# MODEL__ZONES__FREEZER=9,10

# ============================================================================
# 비디오 디코더
# ============================================================================
# auto | ffmpeg | opencv — auto는 NVDEC(hwaccel cuda)+numpy 가용 시 ffmpeg 스트리밍
MODEL__VIDEO__DECODER=auto

# ============================================================================
# CLOSE 정산 타이밍
# ============================================================================
# 인과 배리어 상한 타임아웃 (I17 — 정상 경로 아님)
MODEL__CLOSE__BARRIER_TIMEOUT_S=10.0
# CLOSE 유예 창 (이슈 #8, 원본 close_initial_wait 대응): 문 닫힘·마지막 트리거
# 도착 후 이 시간 동안 확정을 보류 — late trigger 유실 방지. 0=비활성(비권장).
MODEL__CLOSE__GRACE_S=3.0
# 워커 처리 중(queue_pending) 전용 상한 — Jetson 추론이 길 수 있어 넉넉히
MODEL__CLOSE__WORKER_STALL_TIMEOUT_S=120.0
# freezer close 재solve의 비전 조합 중재 (0723 이슈 #17 — 냉동 존 전용):
# 단일 종 ×N 스냅(N≥2)·게이트 실패 시 자격 표(≥3표) 2종 조합이 게이트 안에서
# net을 설명하면 조합 우선. 냉장 존은 4층 재solve 자체를 건너뛴다. 0=비활성.
MODEL__CLOSE__VISION_COMBO=1

# ============================================================================
# 세션/원장/아카이브
# ============================================================================
# 에러 트리거 포함 세션의 결제 정책 (D9/I13): block_payment (fail-closed)
MODEL__SESSION__ERROR_POLICY=block_payment
# 세션 YAML 아카이브 (오판정 사후 분석용) — 빈 문자열이면 비활성
MODEL__SESSION__ARCHIVE_DIR=data/sessions
MODEL__SESSION__ARCHIVE_RETENTION_DAYS=14
# 이벤트 저널 (JSONL, 일자 로테이션)
MODEL__LEDGER__JOURNAL_PATH=logs/events.jsonl
MODEL__LEDGER__JOURNAL_RETENTION_DAYS=14
# EventLog/settler 멱등 캐시 보존 세션 수 (I11)
MODEL__LEDGER__KEEP_SESSIONS=4

# ============================================================================
# 트리거/서버/로깅
# ============================================================================
# 트리거 멱등성 TTL (I7)
MODEL__TRIGGER__IDEMPOTENCY_TTL_S=5.0
# 트레이스 보존 상한 (24h+ soak)
MODEL__TRIGGER__OUTCOMES_KEEP=256
# TensorRT 마이크로배치 (L3 — 설계만, 기본 OFF 유지)
MODEL__VISION__BATCH_SIZE=1
MODEL__SERVER__HOST=0.0.0.0
MODEL__SERVER__PORT=8002
MODEL__LOG_LEVEL=INFO
