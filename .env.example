# CRK-model-HG 환경 설정 예시
#
# 사용법: 이 파일을 .env로 복사한 뒤 기기에 맞게 수정한다.
#   cp .env.example .env
# .env는 serve.py(model-service-hg 기동)가 자동 로드한다. 이미 export된
# 환경변수가 있으면 그것이 우선한다 (os.environ.setdefault).

# ============================================================================
# 필수 — 기기마다 반드시 확인
# ============================================================================

# TensorRT 엔진 경로 (레포에 없음 — CRK-model에서 쓰던 .engine 복사)
MODEL__VISION__YOLO_MODEL_PATH=models/set9_doorfas_0323_imbal.engine

# 기기 캐비닛 타입: refrigerated | freezer
# 냉동 기기는 반드시 freezer로 — 미설정 시 냉장 프로파일(±3g, 무게=정체성)로
# 판정·정산되어 오과금/매출누락이 난다 (이슈 #6 실사고).
MODEL__MACHINE__CABINET_TYPE=freezer

# ============================================================================
# 비전 투표 튜닝 (이슈 #6 — 세션 아카이브 YAML의 vote_summary를 보고 조정)
# ============================================================================
# 판정 흐름: YOLO 검출 → (진입 컷) → 투표 누적 → (ratio/count 게이트)
#            → (conf_floor) → vision_candidates → strict/vision 판정
# vote_summary 읽는 법:
#   entry_dropped_by_camera 큼  → 진입 컷이 너무 높음 (아래 THRESHOLD 낮추기)
#   rejected_by: "ratio"        → 투표 수 부족 (MIN_VOTE_RATIO/COUNT 낮추기)
#   rejected_by: "conf_floor"   → 결합 후 하한에 걸림 (CONF_FLOOR 낮추기)
#   filter_drops_by_stage 큼    → side_roi/hand_path 필터가 지움 (ROI 경계 확인)
#   classes 자체가 비어 있음    → 모델이 정말 못 봄 (모델/카메라 문제)

# 카메라별 투표 진입 임계 — 이 conf 미만 검출은 투표에 안 들어감.
# 원본 코드 기본 0.70, 원본 운영 .env.example은 0.50.
# 냉동(김서림·성에)에서 후보가 안 잡히면 0.50 → 0.35 순으로 낮춰볼 것.
MODEL__VISION__TOP_CONFIDENCE_THRESHOLD=0.50
MODEL__VISION__SIDE_CONFIDENCE_THRESHOLD=0.50

# 후보 채택 임계: 투표율(votes/게이트 통과 프레임) 또는 절대 투표 수 중 하나만
# 넘으면 후보 유지. 원본 운영값은 ratio 0.02 / count 1 (코드 기본 0.05 / 3).
MODEL__VISION__MIN_VOTE_RATIO=0.05
MODEL__VISION__MIN_VOTE_COUNT=3

# 1위 후보 득표 대비 상대 하한 (이슈 #10). 절대 COUNT(3)는 400프레임+ 영상에서
# 노이즈도 통과시킨다 — 8표(1위의 4%)짜리 후보가 판정에 들어가 무게만 맞으면
# 채택되는 사고(비비고 → 메로나 79g×3)의 원인. votes < 1위×SHARE 후보 제거.
# 0 = 비활성. vote_summary의 rejected_by: "share"로 제거 여부 확인 가능.
MODEL__VISION__MIN_VOTE_SHARE=0.1

# 결합 후 weighted_conf 하한 — 원본에는 없는 안전판 (원본 동형 = 0.0).
# 진입 컷을 0으로 낮춰 저신뢰 투표까지 보존할 때만 0.1~0.4로 올려 쓴다.
MODEL__VISION__CONF_FLOOR=0.0

# Side 카메라 ROI 경계 (center_x >= 이 값이면 존 바깥으로 보고 제거).
# 실기에서 side 검출이 거의 전부 제거되면 카메라 장착에 맞게 넓혀볼 것 (0=비활성 아님, 480=사실상 비활성).
MODEL__VISION__SIDE_ROI_MAX_CENTER_X=240

# ============================================================================
# 로드셀 판정 (이슈 #10)
# ============================================================================
# 오염 delta 이중 타깃 재시도: 취출 시 손이 선반을 누르면(접촉 하중) delta와
# 세그먼트 합이 어긋난다(실측 8~18g, 깨끗한 트리거는 0). 이 갭이 아래 값을
# 넘고 delta 타깃 판정이 실패하면 세그먼트 합을 타깃으로 1회 재판정한다.
# YOLO 재실행 없음(순수 CPU, 수 ms). 아주 크게 주면 사실상 비활성.
MODEL__WEIGHT__SEGMENT_RETRY_GAP_GRAMS=5.0

# ============================================================================
# 존 프로파일 (선택)
# ============================================================================
# cabinet_type이 기본 프로파일을 정하고, 특정 존만 냉동으로 오버라이드할 때 사용
# MODEL__ZONES__FREEZER=9,10

# ============================================================================
# 비디오 디코더
# ============================================================================
# auto | ffmpeg | opencv — auto는 NVDEC(hwaccel cuda)+numpy 가용 시 ffmpeg 스트리밍
MODEL__VIDEO__DECODER=auto

# ============================================================================
# CLOSE 정산 타이밍
# ============================================================================
# 인과 배리어 상한 타임아웃 (I17 — 정상 경로 아님)
MODEL__CLOSE__BARRIER_TIMEOUT_S=10.0
# CLOSE 유예 창 (이슈 #8, 원본 close_initial_wait 대응): 문 닫힘·마지막 트리거
# 도착 후 이 시간 동안 확정을 보류 — 카메라가 아직 쓰고 있는 AVI의 late
# trigger 유실(0원 확정 + event rejected) 방지. 0이면 비활성 (권장 안 함).
MODEL__CLOSE__GRACE_S=3.0
# 워커 처리 중(queue_pending) 전용 상한 — Jetson 추론이 길 수 있어 넉넉히
MODEL__CLOSE__WORKER_STALL_TIMEOUT_S=120.0

# ============================================================================
# 세션/원장/아카이브
# ============================================================================
# 에러 트리거 포함 세션의 결제 정책 (D9/I13): block_payment (fail-closed)
MODEL__SESSION__ERROR_POLICY=block_payment
# 세션 YAML 아카이브 (오판정 사후 분석용) — 빈 문자열이면 비활성
MODEL__SESSION__ARCHIVE_DIR=data/sessions
MODEL__SESSION__ARCHIVE_RETENTION_DAYS=14
# 이벤트 저널 (JSONL, 일자 로테이션)
MODEL__LEDGER__JOURNAL_PATH=logs/events.jsonl
MODEL__LEDGER__JOURNAL_RETENTION_DAYS=14
# EventLog/settler 멱등 캐시 보존 세션 수 (I11)
MODEL__LEDGER__KEEP_SESSIONS=4

# ============================================================================
# 교차존 비전 오염 페널티 (docs/0711_idea.md)
# ============================================================================
# 세션 유지 중 타 존 취출 장면이 판별용 AVI에 섞이는 오염을 CLOSE 2차 패스에서
# soft 페널티로 보정한다. 단계별 배포:
#   Phase 1: 둘 다 0 — change_timestamps 계측만 (저널/아카이브 기록)
#   Phase 2: SHADOW=1 — 페널티 ON 정산기를 shadow로 병행, [OPS][SHADOW_DIFF]만 수집
#   Phase 3: PENALTY_ENABLED=1 — primary 승격
MODEL__CROSS_ZONE__PENALTY_ENABLED=0
MODEL__CROSS_ZONE__SHADOW=0
# 카메라 계약 상수 — CRK-CAMERA replay_duration(프리롤)/trigger duration과 맞출 것
MODEL__CROSS_ZONE__REPLAY_S=4.0
MODEL__CROSS_ZONE__TRIGGER_S=3.0
# IO-BOARD 감지 지연 마진 (폴링 0.099s + 필터 지연)
MODEL__CROSS_ZONE__EPSILON_S=0.3
# soft 페널티 계수 (α) — 오염 후보의 표·신뢰도에 곱한다 (하드 제외 아님)
MODEL__CROSS_ZONE__ALPHA=0.5
# 페널티 소스 최소 판정 신뢰도 (θ) — 미만 소스는 제외 (오판 전파 차단)
MODEL__CROSS_ZONE__SOURCE_CONF_MIN=0.35

# ============================================================================
# 트리거/서버/로깅
# ============================================================================
# 트리거 멱등성 TTL (I7)
MODEL__TRIGGER__IDEMPOTENCY_TTL_S=5.0
# 트레이스 보존 상한 (24h+ soak)
MODEL__TRIGGER__OUTCOMES_KEEP=256
# TensorRT 마이크로배치 (L3 — 설계만, 기본 OFF 유지)
MODEL__VISION__BATCH_SIZE=1
MODEL__SERVER__HOST=0.0.0.0
MODEL__SERVER__PORT=8002
MODEL__LOG_LEVEL=INFO
