# CRK-model-HG 환경 설정 예시
#
# 사용법: 이 파일을 .env로 복사한 뒤 기기에 맞게 수정한다.
#   cp freezer.env.example .env
# .env는 serve.py(model-service-hg 기동)가 자동 로드한다. 이미 export된
# 환경변수가 있으면 그것이 우선한다 (os.environ.setdefault).

# ============================================================================
# 필수 — 기기마다 반드시 확인
# ============================================================================

# TensorRT 엔진 경로 (레포에 없음 — CRK-model에서 쓰던 .engine 복사)
MODEL__VISION__YOLO_MODEL_PATH=models/set9_doorfas_0323_imbal.engine

# 기기 캐비닛 타입: refrigerated | freezer
# 냉동 기기는 반드시 freezer로 — 미설정 시 냉장 프로파일(±3g, 무게=정체성)로
# 판정·정산되어 오과금/매출누락이 난다 (이슈 #6 실사고).
MODEL__MACHINE__CABINET_TYPE=freezer

# ============================================================================
# 비전 투표 튜닝 (이슈 #6 — 세션 아카이브 YAML의 vote_summary를 보고 조정)
# ============================================================================
# 판정 흐름: YOLO 검출 → (진입 컷) → 투표 누적 → (ratio/count 게이트)
#            → (conf_floor) → vision_candidates → strict/vision 판정
# vote_summary 읽는 법:
#   entry_dropped_by_camera 큼  → 진입 컷이 너무 높음 (아래 THRESHOLD 낮추기)
#   rejected_by: "ratio"        → 투표 수 부족 (MIN_VOTE_RATIO/COUNT 낮추기)
#   rejected_by: "conf_floor"   → 결합 후 하한에 걸림 (CONF_FLOOR 낮추기)
#   filter_drops_by_stage 큼    → side_roi/hand_path 필터가 지움 (ROI 경계 확인)
#   classes 자체가 비어 있음    → 모델이 정말 못 봄 (모델/카메라 문제)

# 카메라별 투표 진입 임계 — 이 conf 미만 검출은 투표에 안 들어감.
# 원본 코드 기본 0.70, 원본 운영 .env.example은 0.50.
# 냉동(김서림·성에)에서 후보가 안 잡히면 0.50 → 0.35 순으로 낮춰볼 것.
MODEL__VISION__TOP_CONFIDENCE_THRESHOLD=0.4
MODEL__VISION__SIDE_CONFIDENCE_THRESHOLD=0.50

# 후보 채택 임계: 투표율(votes/게이트 통과 프레임) 또는 절대 투표 수 중 하나만
# 넘으면 후보 유지. 원본 운영값은 ratio 0.02 / count 1 (코드 기본 0.05 / 3).
# 참고: 원본의 냉동 전용 하한(freezer_min_vote_ratio/count)은 0.08 / 3 —
# 냉동 단일 기기인 HG에서는 이 전역 노브가 그 역할을 겸한다. 노이즈 후보가
# 자주 살아남으면 원본 냉동 운영값(0.08/3)으로 올려 본다 (P1-7 대응).
MODEL__VISION__MIN_VOTE_RATIO=0.02
MODEL__VISION__MIN_VOTE_COUNT=2

# 1위 후보 득표 대비 상대 하한 (이슈 #10). 절대 COUNT(3)는 400프레임+ 영상에서
# 노이즈도 통과시킨다 — 8표(1위의 4%)짜리 후보가 판정에 들어가 무게만 맞으면
# 채택되는 사고(비비고 → 메로나 79g×3)의 원인. votes < 1위×SHARE 후보 제거.
# 0 = 비활성. vote_summary의 rejected_by: "share"로 제거 여부 확인 가능.
MODEL__VISION__MIN_VOTE_SHARE=0.1

# 결합 후 weighted_conf 하한 — 원본에는 없는 안전판 (원본 동형 = 0.0).
# 진입 컷을 0으로 낮춰 저신뢰 투표까지 보존할 때만 0.1~0.4로 올려 쓴다.
MODEL__VISION__CONF_FLOOR=0.0

# 카메라 conf 결합 가중 (원본 combine() 동형 산식 — P1-4):
#   양카메라 검출: weighted = top·W_TOP + side·W_SIDE
#                            + min(top,side)·COMMON_CLASS_BONUS
#   단일 카메라:   weighted = conf·W_TOP_ONLY (또는 W_SIDE_ONLY)
# 기본은 원본 운영값(0.60/0.40/0.2). 카메라별 신뢰도 차이가 실측되면 조정 —
# 예: side 오검출(의류 산탄)이 과다하면 SIDE를 내리고, top 가림이 잦으면
# TOP을 내린다. *_ONLY는 한쪽만 검출됐을 때 conf가 반토막나지 않게 하는
# 전용 가중이라 W_TOP/W_SIDE와 독립으로 조정 가능.
MODEL__VISION__CONF_WEIGHT_TOP=0.70
MODEL__VISION__CONF_WEIGHT_SIDE=0.30
MODEL__VISION__CONF_WEIGHT_TOP_ONLY=0.80
MODEL__VISION__CONF_WEIGHT_SIDE_ONLY=0.40
MODEL__VISION__CONF_COMMON_CLASS_BONUS=0.2

# Side 카메라 ROI 경계 (center_x >= 이 값이면 존 바깥으로 보고 제거).
# 좌표계는 center-crop 480×480 (2026-07-24 left-crop에서 전환) — 400은
# 원본 left-crop 좌표계의 side_roi_x_max 값을 그대로 이식한 것으로, 크롭
# 원점이 이동(가로축 0→80)해 물리적으로는 다른 경계를 가리킨다. 실기
# 재측정 전까지는 400 유지(현재 방침 — side ROI는 일단 그대로 둠).
# 과거 480(사실상 비활성)은 squash resize 좌표계에서 side 검출이 전멸하던
# 시절의 임시 조치.
# ※ CAMERA_LAYOUT=dual_top_proxy(냉동 dual-top)에서는 side 스트림도 top
#   뷰이므로 이 x-ROI는 생략되고 아래 수직 ROI가 대신 적용된다 (원본 동형).
MODEL__VISION__SIDE_ROI_MAX_CENTER_X=480

# 수직 ROI (원본 정합 웨이브 2 — P1-5 이식). 냉동 실기(dual-top: 공용 스트림
# 2개가 모두 top 뷰)는 CAMERA_LAYOUT=dual_top_proxy로 켠다 — cabinet_type=
# freezer와 조합될 때만 두 카메라 모두 상단 절반(center_y <= Y_SPLIT)의
# 검출만 유지한다 (하단 = 진열 선반 → 진열 오투표의 물리적 차단, 이슈 #16
# D형 "진열 만두 63표"의 원본측 방어선). 좌표계는 center-crop 480×480
# (세로축이라 crop 원점 이동 영향 없음).
# 미설정(dual)이면 기존 동작 그대로 — 실기 vote_summary의
# filter_drops_by_stage.vertical_roi로 제거량을 확인한 뒤 켜는 것을 권장.
# Y_SPLIT은 원본 운영값 240에서 300으로 상향(2026-07-24).
# MODEL__VISION__CAMERA_LAYOUT=dual_top_proxy
MODEL__VISION__FREEZER_ROI_VERTICAL_REGION=upper
MODEL__VISION__FREEZER_ROI_Y_SPLIT=350.0

# 냉장(top+side) 레이아웃 top 카메라 수직 ROI (원본 top_roi_enabled) —
# 트리거 delta가 0이 아닐 때 하단 절반(center_y >= Y_SPLIT)만 유지.
# 냉동 dual-top 실기에서는 미사용이라 기본 off (원본 기본은 true).
MODEL__VISION__TOP_ROI_ENABLED=0
MODEL__VISION__TOP_ROI_Y_SPLIT=240.0

# 손 검출 conf 하한 (원본 hand_confidence_threshold, P1-7 이식) — 이 값
# 미만의 hand 검출은 모션 게이트 래치(I16)·hand_path 궤적에 쓰지 않는다.
# 원본 운영값 0.30. 0 = 비활성.
MODEL__VISION__HAND_CONFIDENCE_THRESHOLD=0.30

# (구 정지 트랙 억제 STATIC_TRACK_* / Baseline 억제 BASELINE_SUPPRESS_* 는
#  2026-07-24 코드에서 삭제 — MOTION_EVIDENCE의 트랙 단위 변위 몰수가 같은
#  물리를 직접 재면서 은퇴했다. 0723 트랙릿 문서 §5, issue #16 실기 4건.)

# ============================================================================
# 로드셀 판정 (이슈 #10)
# ============================================================================
# 오염 delta 이중 타깃 재시도: 취출 시 손이 선반을 누르면(접촉 하중) delta와
# 세그먼트 합이 어긋난다(실측 8~18g, 깨끗한 트리거는 0). 이 갭이 아래 값을
# 넘고 delta 타깃 판정이 실패하면 세그먼트 합을 타깃으로 1회 재판정한다.
# YOLO 재실행 없음(순수 CPU, 수 ms). 아주 크게 주면 사실상 비활성.
MODEL__WEIGHT__SEGMENT_RETRY_GAP_GRAMS=5.0

# 로드셀 안정 판정 (이슈 #14, 0.8s 캐던스): plateau 성립에 STABLE_WINDOW개
# 연속 샘플의 std ≤ STABILITY_THRESHOLD 필요. post-roll 4s = 5샘플이라
# window 3은 마진이 얇다 — delta 0(insufficient_stable_regions)이 잦으면
# 카메라 post-roll 연장이 1순위, window 2 축소는 노이즈 plateau 위험이
# 있는 최후 수단. threshold 2.5는 5g 양자화 bin 경계 토글 1회 허용값 —
# 2.0이면 경계값이 영영 안정 판정을 못 받는다.
MODEL__WEIGHT__STABLE_WINDOW=3
MODEL__WEIGHT__STABILITY_THRESHOLD_GRAMS=2.5

# primary 로드셀 분석기 (이슈 #14): **2026-07-23 bocpd 정식 승격**
# (BOCPD_SHADOW 병행 기록 장치는 승격 확정으로 2026-07-24 삭제).
# 근거 — 이슈 #17 실측 63관측/2 mismatch, 5차 ses-2에서 plateau가
# insufficient_stable_regions로 delta 0(무음 0원 누락)일 때 BOCPD는
# −297.5±2.6에 채널 분해(ch0 −127.5 / ch1 −170)까지 정확. 계약(reason/
# 게이트/반품 안정화/멀티트레이 이벤트)은 동일하고 "안정 구간" 정의만
# 다르다. 회귀 시 plateau로 롤백.
MODEL__LOADCELL__ANALYZER=bocpd

# ============================================================================
# 판정 I-V 노브 (이슈 #15 — FreezerVisionFirst 단계별 임계)
# ============================================================================
# 무게는 개수 산정·검증과 반증에만 쓰고 정체성 선택은 금지(I-V)한다는 전제의
# 경계값들. 비율은 전부 "top 후보 득표 대비".
# SINGLE_SHARE: 이 비율 이상 득표한 후보만 단일 정체성으로 무게 중재 허용
#   (vision 스스로 모호하다고 인정하는 범위). 낮추면 #15형 갈아타기 재발 위험.
# COMBO_SHARE: 다품종 조합 멤버 자격 — 낮추면 배경 후보가 오염 잔차 filler로
#   낌(#10 메로나 79×3), 높이면 정당한 3종 동시 취출(소형 상품)이 조합 불발.
# NEAR_FACTOR: count_gate × 이 배수까지 "접촉 오염 마진"(실측 8~18g)으로 보고
#   top 정체성·개수 보존 PARTIAL. 올리면 count 오판 위험, 내리면 #15형
#   3g 차이 탈락이 부활.
# REFIT_SHARE: top 결정적 반증 시 유일-적합 구제 자격 — 3표(1.75%) 후보가
#   무게 우연으로 COMPLETE 되던 사고(#10 ses-…418)의 하한.
MODEL__JUDGMENT__SINGLE_SHARE=0.5
MODEL__JUDGMENT__COMBO_SHARE=0.3
MODEL__JUDGMENT__NEAR_FACTOR=2.0
MODEL__JUDGMENT__REFIT_SHARE=0.1

# 무게 중재 재설계 (이슈 #16, docs/0722_issue16_arbitration_design.md).
# 원칙: 무게는 거부권만, 복수 적합의 선택은 vision(득표+conf)이 한다.
# COUNT_UNIT_SLACK: 개수당 게이트 가산(g) — gate_n(n)=15+slack×(n−1).
#   DB unit_weight 편차·접촉 오염이 개수에 비례 누적되는 것을 흡수
#   (실사고: 베이글 5개 잔차 32g > flat 15g → 만두 4개 오과금). 0=구 동작.
# CONF_OVERRIDE: single_share(50%) 미달이어도 conf가 이 값 이상(+refit_share
#   득표)이면 ① 적합 자격 — 진열 오염이 득표 순위를 왜곡해도 max-conf는
#   독립 신호 (실사고: conf 1.0 진짜 상품이 19표 vs 오염 63표). 2.0=비활성.
# CONF_MARGIN: 복수 적합 중재에서 conf가 득표 서열을 뒤집는 최소 격차.
#   발동 시 reason "…single_arbitrated"로 아카이브에 남는다. 2.0=비활성.
#   비교는 conf 상한 1.0에서 포화된다: bc ≥ min(0.99, vt+margin) — vt conf
#   > 0.85면 중재가 원리적으로 봉쇄되던 결함 수정 (7차 ses-10 z1: 정답
#   conf 1.0이 0.855+0.15=1.005에 0.005 차로 패배). 단 vt conf가
#   CONF_OVERRIDE 이상이면 포화 미적용 — 둘 다 천장권이면 conf 차이는
#   압축 노이즈라 득표 서열 유지 (8차 ses-4: 0.96/126표 정답이 1.0/66표
#   반납 상품에 뒤집힌 실사고).
MODEL__JUDGMENT__COUNT_UNIT_SLACK=5.0
MODEL__JUDGMENT__CONF_OVERRIDE=0.9
MODEL__JUDGMENT__CONF_MARGIN=0.15

# 무게 우도 score shadow (docs/0722_weight_likelihood_design.md Phase 1):
# 판정에는 미사용 — 이벤트(트레이)별로 score(a) = log P_vision + clamp(log
# L_weight, ±log k) 순위를 계산해 현행 판정과 1위가 다르면 아카이브
# trace.likelihood_shadow에 diff를 기록한다 (reason_codes에
# likelihood_shadow_mismatch). mismatch 세션 + 정답 라벨(label-session)로
# score 정오 비율을 실측한 뒤 Phase 2(중재 대체) 승격을 결정.
# LIKELIHOOD_K: 우도비 상한(clamp) — 1이면 무게 무력(거부권만), 클수록 무게가
#   vision 사전비를 뒤집을 수 있는 폭 확대. conformal 보정 대상.
# LIKELIHOOD_SIGMA_DB: DB unit_weight 개당 편차(g) — gate_n의 개당 slack 5g와
#   같은 물리량. 아카이브 (delta, 확정 배정) 잔차 분포로 보정.
#   6.3 = 5차 배치 실측 6.25 (--since로 최신 코드 세션만 — 이전 제안 8.4는
#   구버전 혼합 오염). 라이브러리 기본값은 설계 문서의 5.0 유지.
MODEL__JUDGMENT__LIKELIHOOD_SHADOW=1
MODEL__JUDGMENT__LIKELIHOOD_K=20.0
MODEL__JUDGMENT__LIKELIHOOD_SIGMA_DB=6.3

# 세션 트레이 메모리 (ledger/tray_memory.py, Phase 1: likelihood shadow의
# log_p_tray 항으로만 소비 — 판정·정산 무변경). 정적 planogram(금지)과 달리
# 운영 입력이 없고, 세션 OPEN마다 리셋된다(cold-start = 현행과 동일).
# 존마다 좌/우 트레이(채널 2개)가 별개 상품을 가질 수 있으므로 키는
# (zone, channel)이며, 같은 상품이 여러 트레이에 있을 수 있어 항상 소프트
# 가감점만 준다. 등록은 "COMPLETE + 무게 뒷받침" 판정만 (refit 제외).
# vision 1위 일치 조건은 Phase 1에서 제외 — 오염 존일수록 top 불일치가
# 흔한데 그게 정확히 prior가 필요한 상황 (5차 ses-10 닭-달걀, tray_memory.py).
# BOOST: 같은 트레이에서 이미 확정된 정체성 가점 (동일 트레이 반복 취출 일관성)
# PENALTY: 같은 세션의 다른 트레이에서 이미 설명된 정체성 감점 — 2.5는
#   이슈 #17 ses-5(존5에서 확정된 44가 존4에서 44×3으로 재과금)의 score 격차
#   2.43을 뒤집는 최소값 근방. 아카이브 라벨 실측으로 보정할 것.
MODEL__JUDGMENT__TRAY_PRIOR=1
MODEL__JUDGMENT__TRAY_PRIOR_BOOST=0.7
MODEL__JUDGMENT__TRAY_PRIOR_PENALTY=2.5

# 무게 미검증 count=1 partial 청구의 conf 하한 (원본 multi_kind_min_confidence
# 동형). 실기 ses-3-1784788285: 5표/청구 conf 0.157짜리 identity partial이
# 잔차 65g 오상품을 과금 — 저증거 청구를 차단한다. 0 = 비활성(구 동작).
MODEL__JUDGMENT__PARTIAL_MIN_CONFIDENCE=0.18

# ============================================================================
# 조기 종료 · 모션 게이트 (프레임 처리량)
# ============================================================================
# EARLY_TERMINATION: removal & 비freezer 한정. 끄면 전 프레임 추론(정확도
# 상한, 처리시간 증가). 켜도 freezer 프로파일에서는 I15로 항상 비활성.
MODEL__VISION__EARLY_TERMINATION=1
# 모션 변위 증거 (issue #16 후속 — 원본 MOTION_MIN_DISPLACEMENT_PX 이식):
# 클래스 트랙의 누적 변위가 max(floor, bbox×0.10)을 못 넘으면 그 카메라의
# 표를 combine에서 몰수. "집어간 상품은 움직이고 진열 상품은 안 움직인다"의
# 직접 검사 — baseline(손 타이밍 대리 신호)이 잡으려던 깜빡이는 정지 물체까지
# 손 신호 없이 커버한다. vote_summary의 rejected_by: "no_motion" +
# motion_evidence 블록으로 관측. FLOOR 비우면 프로파일 기본(냉장 10/냉동 12px —
# 픽셀 임계라 1:1 크롭이면 crop 원점과 무관하게 유효, 원본 운영값 동형).
# 0=비활성 (롤백).
MODEL__VISION__MOTION_EVIDENCE=1
# MODEL__VISION__MOTION_EVIDENCE_FLOOR_PX=
# T2 held 트랙 강등 (0713 A-2의 트랙 단위 재구현, 0723 트랙릿 문서 §8):
# 프리롤 head 구간(첫 30 디코드 프레임)부터 지속 관측된(carried-in) 트랙의
# 표를 combine에서 몰수. 클래스 단위 A-2와 달리 같은 클래스의 취출 트랙
# 표는 유지된다(S2 해소). 프리롤 부족 트리거(관측 < 60프레임)는 자동 비활성.
# 모드: off / shadow(vote_summary.held_shadow 관측만, 판정 무변경) / active.
# 승격 게이트: analyze-sessions에서 정답 클래스 held 플래그 0건 확인 후.
# MIN_HEAD 5 = 0713 §10 실측(held 27~33 vs 진짜 취출 0~2)의 분리 하한.
MODEL__VISION__HELD_TRACK_DEMOTION=shadow
MODEL__VISION__HELD_TRACK_MIN_HEAD=5
# 트랙릿 잔여 갭 4종 (0723 트랙릿 문서 §2, shadow-first — vote_summary.
# tube_shadow에 클래스별 현행/가상 유효표 병기, analyze-sessions "튜브
# shadow" 섹션이 라벨 정오 대조 = 승격 게이트).
# ① TUBE_IDENTITY (T2'/G1, 갭 4): 클래스 무관 튜브의 다수결에서 결정적
#   소수(관측 < 최다 클래스의 30%)인 클래스 표를 몰수 — 8차 의류 산탄의
#   "한 궤적, 깜빡이는 클래스" 시그니처 대응. 표 이전이 아니라 몰수라
#   fail-safe 방향이지만 G1 역전 위험 실측 전 shadow 유지.
# ② VOTE_RECOVERY (갭 2, ByteTrack 2단계의 표 버전): 변위 통과 트랙 +
#   같은 (클래스, 트랙) 진입 표 앵커가 있는 저신뢰(≥ FLOOR) 검출의 표를
#   회수 — 빠른 취출 표 기아(5차 23이 1표) 대응. 앵커 없는 순저신뢰
#   궤적(의류)은 회수 불가.
# ③ TRACK_MIN_HITS (갭 1 probation): 총 관측 < N 트랙의 표 몰수. 0=off.
#   단절된 진짜 상품 트랙도 단명이라 fail-closed — tube_shadow의 short
#   계측(고정 probe 3) 실측 후에만 켤 것.
# ④ TRACK_MAX_GAP (갭 1 소멸): 공백 > N 추론프레임 트랙 사망. 0=무소멸.
#   G2 재연관 창(12프레임)과 함께 튜닝 — 같은 fail-closed 방향이라 기본 off.
MODEL__VISION__TUBE_IDENTITY=shadow
MODEL__VISION__VOTE_RECOVERY=shadow
MODEL__VISION__VOTE_RECOVERY_FLOOR=0.35
MODEL__VISION__TRACK_MIN_HITS=0
MODEL__VISION__TRACK_MAX_GAP=0
# MOTION_GATE_*: 비우면 프로파일 기본(냉장 0.02/8, 냉동 0.005/4) 유지.
# THRESHOLD를 올리면 스킵 증가(처리 절약, 정지 프레임 증거 소실 없음 —
# keepalive가 상한), 내리면 거의 전 프레임 추론. KEEPALIVE는 연속 스킵 상한.
# MODEL__VISION__MOTION_GATE_THRESHOLD=
# MODEL__VISION__MOTION_GATE_KEEPALIVE=

# ============================================================================
# 교차존 비전 오염 페널티 (docs/cross_zone_penalty.md, CLOSE 2차 패스)
# ============================================================================
# 세션 유지 중 타 존 취출 장면이 판별용 AVI에 섞이는 오염을 CLOSE 2차 패스에서
# soft 페널티로 보정한다. Phase 3 승격 완료 (2026-07-21): 기본 ON.
# 비활성화하려면 PENALTY_ENABLED=0 (Phase 2용 SHADOW 장치는 승격 확정으로
# 2026-07-24 삭제).
MODEL__CROSS_ZONE__PENALTY_ENABLED=1
# 오염 창 = [min앵커−REPLAY−ε, max앵커+TRIGGER+ε] — CRK-CAMERA 계약
# (replay_duration/trigger duration)과 단일 소스로 맞출 것.
MODEL__CROSS_ZONE__REPLAY_S=4.0
MODEL__CROSS_ZONE__TRIGGER_S=4.0
# IO-BOARD 감지 지연 마진 (ε): 폴링 0.8s(지배 항) + serial/SSE ~0.1s + 여유.
# 구값 0.3은 0.099s 폴링 + EMA 꼬리 시절 산정값. sign-flip relatch(최대 2.4s,
# 존 무게 0 교차 시)는 의도적으로 미포함 — 과도한 창 확장 방지.
MODEL__CROSS_ZONE__EPSILON_S=1.0
# soft 페널티 계수 (α) — 오염 후보의 표·신뢰도에 곱한다 (하드 제외 아님)
MODEL__CROSS_ZONE__ALPHA=0.5
# SOURCE_CONF_MIN: 페널티 소스로 인정할 최소 판정 conf (오판 전파 차단, θ).
#   0.35 권장 — 0.5는 저conf 난장 장면(공유 영상·저득표 = 오염이 가장 심한
#   상황)에서 기제 전체를 꺼버린다 (9차 ses-8: 기기 0.5가 conf 0.393 판정을
#   소스에서 조용히 탈락시켜 상호 강등 가드·페널티가 통째로 무발동 —
#   cross_zone_source_low_conf 진단 note로 이제 관측 가능). 상호 강등의
#   안전은 mutual_exempt 가드가 따로 담당하므로 θ를 높게 잡을 이유가 없다.
#   ※ 기기 .env가 0.5로 남아 있으면 0.35로 내릴 것.
MODEL__CROSS_ZONE__SOURCE_CONF_MIN=0.35

# ============================================================================
# 세션 고스트 원장 (0723 이슈 #17 P1, ledger/ghost_ledger.py, CLOSE 2차 패스)
# ============================================================================
# 옷 프린트 유령 표(실측 c13·c24): 사람을 따라다니며 존마다 자격 표를 얻지만
# 세션 전체에서 무게 뒷받침(COMPLETE, refit/near_gate 제외) 과금이 0인
# 클래스를 강등한다. 트리거 안에서는 진짜와 구분 불가 — 세션 스코프 신호.
# MODE: off | shadow | active — shadow(기본)는 ghost_classes/ghost_shadow
#   notes만 기록. active 승격은 라벨 대조에서 정답 클래스 오플래그율 확인 후
#   (알려진 위험: 과금을 빼앗긴 진짜 클래스의 오플래그 — ghost_ledger.py).
# MIN_ZONES: 유령 판정 최소 존 수 (1 금지 방향 — 단일 존 등장은 정상)
# VOTE_FLOOR: 존 등장으로 인정할 최소 자격 표 수 (저득표 스파이크 차단)
# ALPHA: soft 페널티 계수 (cross-zone ALPHA와 같은 의미, 하드 제외 금지)
MODEL__GHOST__MODE=shadow
MODEL__GHOST__MIN_ZONES=2
MODEL__GHOST__VOTE_FLOOR=3
MODEL__GHOST__ALPHA=0.5

# ============================================================================
# 존 프로파일 (선택)
# ============================================================================
# cabinet_type이 기본 프로파일을 정하고, 특정 존만 냉동으로 오버라이드할 때 사용
# MODEL__ZONES__FREEZER=9,10

# ============================================================================
# 비디오 디코더
# ============================================================================
# auto | ffmpeg | opencv — auto는 NVDEC(hwaccel cuda)+numpy 가용 시 ffmpeg 스트리밍
MODEL__VIDEO__DECODER=auto

# ============================================================================
# CLOSE 정산 타이밍
# ============================================================================
# 인과 배리어 상한 타임아웃 (I17 — 정상 경로 아님)
MODEL__CLOSE__BARRIER_TIMEOUT_S=10.0
# CLOSE 유예 창 (이슈 #8, 원본 close_initial_wait 대응): 문 닫힘·마지막 트리거
# 도착 후 이 시간 동안 확정을 보류 — 카메라가 아직 쓰고 있는 AVI의 late
# trigger 유실(0원 확정 + event rejected) 방지. 0이면 비활성 (권장 안 함).
MODEL__CLOSE__GRACE_S=3.0
# 워커 처리 중(queue_pending) 전용 상한 — Jetson 추론이 길 수 있어 넉넉히
MODEL__CLOSE__WORKER_STALL_TIMEOUT_S=120.0
# 0723 이슈 #17 (3+44 → 44×4 스냅 7회 재발): freezer close 재solve의 단일 종
# ×N 스냅(N≥2)·게이트 실패 시, 그 존에서 자격 표(≥3표)를 받은 2종 조합이
# 게이트 안에서 net을 설명하면 조합을 우선한다. 게이트 안 동률이면 무게는
# 거부권을 행사하지 않은 것 — 선택은 vision (0722 중재 설계 원칙). 0=비활성.
MODEL__CLOSE__VISION_COMBO=1

# ============================================================================
# 세션/원장/아카이브
# ============================================================================
# 에러 트리거 포함 세션의 결제 정책 (D9/I13): block_payment (fail-closed)
MODEL__SESSION__ERROR_POLICY=block_payment
# 세션 YAML 아카이브 (오판정 사후 분석용) — 빈 문자열이면 비활성
MODEL__SESSION__ARCHIVE_DIR=data/sessions
MODEL__SESSION__ARCHIVE_RETENTION_DAYS=14
# 이벤트 저널 (JSONL, 일자 로테이션)
MODEL__LEDGER__JOURNAL_PATH=logs/events.jsonl
MODEL__LEDGER__JOURNAL_RETENTION_DAYS=14
# EventLog/settler 멱등 캐시 보존 세션 수 (I11)
MODEL__LEDGER__KEEP_SESSIONS=4

# ============================================================================
# 트리거/서버/로깅
# ============================================================================
# 트리거 멱등성 TTL (I7)
MODEL__TRIGGER__IDEMPOTENCY_TTL_S=5.0
# 트레이스 보존 상한 (24h+ soak)
MODEL__TRIGGER__OUTCOMES_KEEP=256
# TensorRT 마이크로배치 (L3 — 설계만, 기본 OFF 유지)
MODEL__VISION__BATCH_SIZE=1
MODEL__SERVER__HOST=0.0.0.0
MODEL__SERVER__PORT=8002
MODEL__LOG_LEVEL=INFO

# ④ refit 복수 적합 중재의 절대 conf 하한 (실기 ses-1 ch1: 0.69 유령이
# margin 우세만으로 오과금). 승자는 자체로 선명(기본 0.8)해야 한다.
# 2.0 = 중재 비활성(유일-적합만).
MODEL__JUDGMENT__REFIT_ARB_CONF_FLOOR=0.8
